{
  "name": "galaxyjs",
  "version": "3.0.0",
  "description": "GalaxyJS v3 'Nova' — a zero-dependency cosmic animation & UI component library. One unified API (Galaxy.create), 13 canvas animations, themeable UI components, full accessibility & reduced-motion support.",
  "main": "galaxy.js",
  "module": "galaxy.js",
  "types": "galaxy.d.ts",
  "unpkg": "galaxy.js",
  "jsdelivr": "galaxy.js",
  "style": "galaxy.css",
  "sideEffects": [
    "galaxy.js",
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./galaxy.d.ts",
      "import": "./galaxy.js",
      "require": "./galaxy.js",
      "default": "./galaxy.js"
    },
    "./css": "./galaxy.css",
    "./galaxy.css": "./galaxy.css"
  },
  "scripts": {
    "start": "live-server --port=3000 --open=index.html",
    "dev": "live-server --port=3000 --open=index.html",
    "manifest": "node mcp/build-manifest.cjs",
    "mcp": "node mcp/server.mjs",
    "lint": "eslint galaxy.js",
    "format": "prettier --write '**/*.{js,css,html,md}'"
  },
  "bin": {
    "galaxyjs-mcp": "mcp/server.mjs"
  },
  "keywords": [
    "animation",
    "cosmic",
    "space",
    "galaxy",
    "javascript",
    "css",
    "particles",
    "effects",
    "astronomy",
    "physics",
    "black-hole",
    "pulsar",
    "wormhole",
    "supernova",
    "nebula",
    "stars",
    "universe",
    "cosmos",
    "scientific",
    "interactive",
    "web-animations-api",
    "performance",
    "accessibility",
    "object-pooling",
    "canvas-optimization",
    "adaptive-quality"
  ],
  "author": {
    "name": "Ed Chen",
    "url": "https://www.edwson.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Edwson/GalaxyJS.git"
  },
  "bugs": {
    "url": "https://github.com/Edwson/GalaxyJS/issues"
  },
  "homepage": "https://github.com/Edwson/GalaxyJS",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Edwson"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "live-server": "^1.2.2",
    "prettier": "^2.8.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "files": [
    "galaxy.js",
    "galaxy.css",
    "galaxy.d.ts",
    "galaxy.manifest.json",
    "llms.txt",
    "index.html",
    "mcp/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "directories": {
    "css": "css",
    "js": "js",
    "examples": "examples"
  },
  "publishConfig": {
    "access": "public"
  },
  "contributors": [
    {
      "name": "GalaxyJS Team",
      "email": "team@galaxyjs.dev"
    }
  ],
  "bundledDependencies": [],
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "private": false,
  "workspaces": [],
  "config": {
    "port": 3000
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "indent": [
        "error",
        2
      ],
      "linebreak-style": [
        "error",
        "unix"
      ],
      "quotes": [
        "error",
        "single"
      ],
      "semi": [
        "error",
        "always"
      ]
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2
  },
  "bundleDependencies": []
}
