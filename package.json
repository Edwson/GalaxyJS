{
  "name": "galaxyjs",
  "version": "3.2.0",
  "description": "GalaxyJS v3 'Nova' \u2014 a zero-dependency cosmic animation & UI component library. One unified API (Galaxy.create), 60 canvas animations, themeable UI components, full accessibility & reduced-motion support.",
  "main": "galaxy.js",
  "module": "galaxy.js",
  "types": "galaxy.d.ts",
  "unpkg": "galaxy.min.js",
  "jsdelivr": "galaxy.min.js",
  "style": "galaxy.css",
  "sideEffects": [
    "galaxy.js",
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./galaxy.d.ts",
      "import": "./galaxy.js",
      "require": "./galaxy.js",
      "default": "./galaxy.js"
    },
    "./css": "./galaxy.css",
    "./galaxy.css": "./galaxy.css"
  },
  "scripts": {
    "start": "live-server --port=3000 --open=index.html",
    "dev": "live-server --port=3000 --open=index.html",
    "manifest": "node mcp/build-manifest.cjs",
    "build:min": "node build.mjs",
    "mcp": "node mcp/server.mjs",
    "lint": "eslint .",
    "format": "prettier --write '**/*.{js,css,html,md}'",
    "test": "node test.mjs",
    "test:mcp": "node test-mcp.mjs",
    "test:all": "npm test && npm run test:mcp",
    "validate": "npm run manifest && npm run lint && npm run build:min && npm run test:all",
    "prepublishOnly": "npm run manifest && npm run build:min && npm test"
  },
  "bin": {
    "galaxyjs-mcp": "mcp/server.mjs"
  },
  "keywords": [
    "animation",
    "cosmic",
    "space",
    "galaxy",
    "javascript",
    "css",
    "particles",
    "effects",
    "astronomy",
    "physics",
    "black-hole",
    "pulsar",
    "wormhole",
    "supernova",
    "nebula",
    "stars",
    "universe",
    "cosmos",
    "scientific",
    "interactive",
    "web-animations-api",
    "performance",
    "accessibility",
    "object-pooling",
    "canvas-optimization",
    "adaptive-quality"
  ],
  "author": {
    "name": "Ed Chen",
    "url": "https://www.edwson.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Edwson/GalaxyJS.git"
  },
  "bugs": {
    "url": "https://github.com/Edwson/GalaxyJS/issues"
  },
  "homepage": "https://github.com/Edwson/GalaxyJS",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Edwson"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "csso": "^5.0.5",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "live-server": "^1.2.2",
    "prettier": "^2.8.0",
    "terser": "^5.48.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "files": [
    "galaxy.js",
    "galaxy.min.js",
    "galaxy.css",
    "galaxy.min.css",
    "galaxy.d.ts",
    "galaxy.manifest.json",
    "llms.txt",
    "index.html",
    "mcp/",
    "docs/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2
  }
}
